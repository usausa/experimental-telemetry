@page "/traces"
@rendermode InteractiveServer
@implements IDisposable
@inject ITelemetryStore Store

<PageTitle>Traces - TelemetryServer</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">Traces</MudText>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">
    Trace ごとに集約しています。行をクリックすると Span のタイムラインを展開します (@summaries.Count 件 / 最大 200)。
</MudText>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
    <MudSelect T="string" Label="Service" Value="@selectedService" ValueChanged="OnServiceChanged"
               Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:200px">
        <MudSelectItem T="string" Value="@(string.Empty)">(All)</MudSelectItem>
        @foreach (var s in serviceNames)
        {
            <MudSelectItem T="string" Value="@s">@s</MudSelectItem>
        }
    </MudSelect>
    <MudTextField @bind-Value="filter" Placeholder="Root span 名で絞り込み..." Immediate="true"
                  Variant="Variant.Outlined" Margin="Margin.Dense"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  Style="max-width:300px" />
    <MudSpacer />
    <MudButton Variant="Variant.Outlined" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Refresh" OnClick="Refresh">Refresh</MudButton>
</MudStack>

<MudTable Items="Filtered()" Dense="true" Hover="true" Elevation="1" T="TraceSummary"
          OnRowClick="OnRowClick">
    <HeaderContent>
        <MudTh Style="width:90px">Time</MudTh>
        <MudTh Style="width:160px">Service</MudTh>
        <MudTh>Root span</MudTh>
        <MudTh Style="width:80px">Spans</MudTh>
        <MudTh Style="width:80px">Errors</MudTh>
        <MudTh Style="width:100px">Duration</MudTh>
        <MudTh Style="width:140px">Trace ID</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd Style="font-family:monospace;font-size:0.8rem">@context.StartTime.ToLocalTime().ToString("HH:mm:ss")</MudTd>
        <MudTd>
            @context.PrimaryService
            @if (context.Services.Count > 1)
            {
                <MudChip T="string" Size="Size.Small" Class="ml-1" Variant="Variant.Outlined">+@(context.Services.Count - 1)</MudChip>
            }
        </MudTd>
        <MudTd>
            <MudIcon Icon="@(expandedTraceId == context.TraceId ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ChevronRight)"
                     Size="Size.Small" Class="mr-1" />
            @context.RootSpanName
        </MudTd>
        <MudTd Style="text-align:right;font-family:monospace">@context.SpanCount</MudTd>
        <MudTd>
            @if (context.ErrorCount > 0)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Error">@context.ErrorCount</MudChip>
            }
            else
            {
                <span class="mud-text-secondary">-</span>
            }
        </MudTd>
        <MudTd Style="text-align:right;font-family:monospace">@FormatDuration(context.Duration)</MudTd>
        <MudTd Style="font-family:monospace;font-size:0.75rem" Class="mud-text-secondary">@ShortId(context.TraceId)</MudTd>
    </RowTemplate>
    <ChildRowContent>
        @if (expandedTraceId == context.TraceId && detail is not null)
        {
            <MudTr>
                <td colspan="7" style="padding:8px 12px;background:var(--mud-palette-background-grey)">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Trace</MudText>
                        <MudText Typo="Typo.caption" Style="font-family:monospace">@detail.TraceId</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">·</MudText>
                        <MudText Typo="Typo.caption">@detail.Spans.Count spans across @detail.Services.Count service(s)</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">·</MudText>
                        <MudText Typo="Typo.caption">@FormatDuration(detail.Duration)</MudText>
                    </MudStack>
                    <SpanGantt Trace="@detail" Width="900" />
                </td>
            </MudTr>
        }
    </ChildRowContent>
    <NoRecordsContent>
        <MudText Class="pa-4 mud-text-secondary">No traces.</MudText>
    </NoRecordsContent>
</MudTable>

@code {
    private IReadOnlyList<TraceSummary> summaries = Array.Empty<TraceSummary>();
    private IReadOnlyList<string> serviceNames = Array.Empty<string>();
    private string selectedService = string.Empty;
    private string filter = string.Empty;
    private string? expandedTraceId;
    private TraceDetail? detail;

    protected override void OnInitialized()
    {
        Refresh();
        Store.Changed += OnStoreChanged;
    }

    private void OnStoreChanged(object? sender, EventArgs e) =>
        InvokeAsync(() => { Refresh(); StateHasChanged(); });

    private void Refresh()
    {
        serviceNames = Store.GetServiceNames();
        if (!string.IsNullOrEmpty(selectedService) && !serviceNames.Contains(selectedService))
        {
            selectedService = string.Empty;
        }
        var svc = string.IsNullOrEmpty(selectedService) ? null : selectedService;
        summaries = Store.GetTraces(svc);
        if (expandedTraceId is not null)
        {
            detail = Store.GetTrace(expandedTraceId);
            if (detail is null)
            {
                expandedTraceId = null;
            }
        }
    }

    private IEnumerable<TraceSummary> Filtered()
    {
        if (string.IsNullOrWhiteSpace(filter))
        {
            return summaries;
        }
        return summaries.Where(t => t.RootSpanName.Contains(filter, StringComparison.OrdinalIgnoreCase));
    }

    private void OnRowClick(TableRowClickEventArgs<TraceSummary> args)
    {
        if (args.Item is null)
        {
            return;
        }
        if (expandedTraceId == args.Item.TraceId)
        {
            expandedTraceId = null;
            detail = null;
        }
        else
        {
            expandedTraceId = args.Item.TraceId;
            detail = Store.GetTrace(args.Item.TraceId);
        }
    }

    private void OnServiceChanged(string value)
    {
        selectedService = value ?? string.Empty;
        Refresh();
    }

    private static string ShortId(string id) =>
        string.IsNullOrEmpty(id) ? "-" : id[..Math.Min(12, id.Length)];

    private static string FormatDuration(TimeSpan d)
    {
        if (d.TotalSeconds >= 1)
        {
            return d.TotalSeconds.ToString("0.00") + "s";
        }
        if (d.TotalMilliseconds >= 1)
        {
            return d.TotalMilliseconds.ToString("0") + "ms";
        }
        return (d.TotalMilliseconds * 1000).ToString("0") + "us";
    }

    public void Dispose() => Store.Changed -= OnStoreChanged;
}
