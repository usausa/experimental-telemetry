@using System.Globalization
@using System.Net
@using System.Text
@using TelemetryServer.Telemetry.Models

<div class="gantt-container" style="width:100%;overflow-x:auto">
    @if (Trace is null || rowCount == 0)
    {
        <div class="mud-text-secondary" style="padding:1rem">No spans.</div>
    }
    else
    {
        <svg width="@Width" height="@height" viewBox="0 0 @Width @height"
             style="font-family:Inter,Roboto,sans-serif;font-size:11px;display:block">
            @svgBody
        </svg>
    }
</div>

@code {
    [Parameter, EditorRequired] public TraceDetail? Trace { get; set; }
    [Parameter] public int Width { get; set; } = 880;

    private const int LabelAreaWidth = 280;
    private const int RowHeight = 24;
    private const int HeaderHeight = 22;
    private const int BarVerticalPad = 5;
    private const double PlotRightPad = 80;

    private MarkupString svgBody;
    private int rowCount;
    private int height = 60;

    protected override void OnParametersSet()
    {
        svgBody = default;
        rowCount = 0;
        height = 60;

        if (Trace is null || Trace.Spans.Count == 0)
        {
            return;
        }

        var minT = Trace.StartTime;
        var maxT = Trace.EndTime;
        if (minT == maxT)
        {
            maxT = minT.AddMilliseconds(1);
        }
        double plotLeft = LabelAreaWidth;
        var plotRight = Width - PlotRightPad;
        if (plotRight <= plotLeft + 20)
        {
            plotRight = plotLeft + 20;
        }

        var byId = new Dictionary<string, SpanEntry>(StringComparer.Ordinal);
        foreach (var s in Trace.Spans)
        {
            byId[s.SpanId] = s;
        }

        var ordered = Trace.Spans.OrderBy(s => s.StartTime).ToList();
        var depths = new Dictionary<string, int>(StringComparer.Ordinal);
        foreach (var s in ordered)
        {
            depths[s.SpanId] = ComputeDepth(s, byId, depths);
        }

        rowCount = ordered.Count;
        height = HeaderHeight + (rowCount * RowHeight) + 6;

        var sb = new StringBuilder();

        // X axis ticks across full timeline
        for (var i = 0; i <= 4; i++)
        {
            var t = i / 4.0;
            var x = plotLeft + (t * (plotRight - plotLeft));
            AppendLine(sb, x, HeaderHeight, x, height, "currentColor", 0.08);
            var time = minT.AddSeconds(t * (maxT - minT).TotalSeconds);
            var rel = (time - minT).TotalMilliseconds;
            var label = rel < 1000
                ? rel.ToString("0", CultureInfo.InvariantCulture) + "ms"
                : (rel / 1000).ToString("0.00", CultureInfo.InvariantCulture) + "s";
            AppendText(sb, x, 14, "middle", "currentColor", 0.7, label);
        }

        // Vertical separator between label area and plot
        AppendLine(sb, plotLeft, HeaderHeight, plotLeft, height, "currentColor", 0.18);

        // Rows
        for (var i = 0; i < ordered.Count; i++)
        {
            var s = ordered[i];
            var depth = depths[s.SpanId];
            var rowY = HeaderHeight + (i * RowHeight);
            var labelX = 8 + (depth * 12);
            var labelY = rowY + 16;
            var barStart = MapX(s.StartTime, minT, maxT, plotLeft, plotRight);
            var barEnd = MapX(s.EndTime, minT, maxT, plotLeft, plotRight);
            var barW = Math.Max(2, barEnd - barStart);
            var dur = s.EndTime - s.StartTime;
            var color = StatusColor(s.StatusCode);

            var serviceEsc = WebUtility.HtmlEncode(s.Resource.ServiceName);
            var nameEsc = WebUtility.HtmlEncode(Truncate(s.Name, 40));
            sb.Append(CultureInfo.InvariantCulture,
                $"<text x=\"{Fmt(labelX)}\" y=\"{Fmt(labelY)}\" font-size=\"11\">");
            sb.Append(CultureInfo.InvariantCulture,
                $"<tspan fill=\"currentColor\" fill-opacity=\"0.55\">{serviceEsc}</tspan>");
            sb.Append(CultureInfo.InvariantCulture,
                $"<tspan fill=\"currentColor\" fill-opacity=\"0.95\" font-weight=\"500\"> {nameEsc}</tspan>");
            sb.Append("</text>");

            var tooltipText = string.Create(CultureInfo.InvariantCulture,
                $"{s.Resource.ServiceName} / {s.Name}\nstatus={s.StatusCode}\nduration={FormatDuration(dur)}");
            var tooltip = WebUtility.HtmlEncode(tooltipText);
            sb.Append(CultureInfo.InvariantCulture,
                $"<rect x=\"{Fmt(barStart)}\" y=\"{Fmt(rowY + BarVerticalPad)}\" width=\"{Fmt(barW)}\" height=\"{RowHeight - (BarVerticalPad * 2)}\" fill=\"{color}\" rx=\"2\"><title>{tooltip}</title></rect>");

            AppendText(sb, barStart + barW + 4, labelY, "start", "currentColor", 0.8,
                FormatDuration(dur), fontSize: 10);
        }

        svgBody = new MarkupString(sb.ToString());
    }

    private static int ComputeDepth(SpanEntry span, Dictionary<string, SpanEntry> byId, Dictionary<string, int> known)
    {
        if (string.IsNullOrEmpty(span.ParentSpanId) || !byId.ContainsKey(span.ParentSpanId))
        {
            return 0;
        }
        if (known.TryGetValue(span.ParentSpanId, out var pd))
        {
            return pd + 1;
        }
        return 1;
    }

    private static double MapX(DateTimeOffset t, DateTimeOffset minT, DateTimeOffset maxT, double left, double right)
    {
        var span = (maxT - minT).TotalSeconds;
        if (span <= 0)
        {
            return left;
        }
        var pos = Math.Clamp((t - minT).TotalSeconds / span, 0, 1);
        return left + (pos * (right - left));
    }

    private static string StatusColor(string status) => (status?.ToUpperInvariant()) switch
    {
        "ERROR" => "#ef5350",
        "OK" => "#66bb6a",
        _ => "#90a4ae",
    };

    private static string FormatDuration(TimeSpan d)
    {
        if (d.TotalSeconds >= 1)
        {
            return d.TotalSeconds.ToString("0.00", CultureInfo.InvariantCulture) + "s";
        }
        if (d.TotalMilliseconds >= 1)
        {
            return d.TotalMilliseconds.ToString("0", CultureInfo.InvariantCulture) + "ms";
        }
        return (d.TotalMilliseconds * 1000).ToString("0", CultureInfo.InvariantCulture) + "us";
    }

    private static string Truncate(string s, int max) =>
        s.Length <= max ? s : s[..(max - 1)] + "…";

    private static string Fmt(double v) => v.ToString("0.##", CultureInfo.InvariantCulture);

    private static void AppendLine(StringBuilder sb, double x1, double y1, double x2, double y2, string stroke, double opacity)
    {
        sb.Append(CultureInfo.InvariantCulture,
            $"<line x1=\"{Fmt(x1)}\" y1=\"{Fmt(y1)}\" x2=\"{Fmt(x2)}\" y2=\"{Fmt(y2)}\" stroke=\"{stroke}\" stroke-opacity=\"{opacity:0.##}\" />");
    }

    private static void AppendText(StringBuilder sb, double x, double y, string anchor, string fill, double opacity, string content, int fontSize = 0)
    {
        sb.Append(CultureInfo.InvariantCulture, $"<text x=\"{Fmt(x)}\" y=\"{Fmt(y)}\"");
        if (!string.IsNullOrEmpty(anchor) && anchor != "start")
        {
            sb.Append(CultureInfo.InvariantCulture, $" text-anchor=\"{anchor}\"");
        }
        sb.Append(CultureInfo.InvariantCulture, $" fill=\"{fill}\" fill-opacity=\"{opacity:0.##}\"");
        if (fontSize > 0)
        {
            sb.Append(CultureInfo.InvariantCulture, $" font-size=\"{fontSize}\"");
        }
        sb.Append('>')
            .Append(WebUtility.HtmlEncode(content))
            .Append("</text>");
    }
}
