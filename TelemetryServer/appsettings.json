{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5080",
        "Protocols": "Http1AndHttp2"
      },
      "Grpc": {
        "Url": "http://0.0.0.0:4317",
        "Protocols": "Http2"
      }
    }
  },
  "TelemetryStore": {
    "DatabasePath": "App_Data/telemetry.db",
    "MaxPointsPerMetricSeries": 500,
    "MaxLogsPerService": 2000,
    "MaxTraces": 500,
    "MaxSpansPerTrace": 200
  }
}
